# AliExpress crawler runtime config
ELASTICSEARCH_URL=http://user:password@host:9200
ELASTICSEARCH_INDEX_URLS=user1_aliexpress_us_product_urls
ELASTICSEARCH_BULK_CHUNK_SIZE=50

# Speed knobs (defaults in alilj.py already favor faster URL crawl)
# REQUEST_DELAY_MS=600,1200
# GOTO_SETTLE_MS=800
# SCROLL_API_TIMEOUT_MS=3500
# SCROLL_FALLBACK_MS=1200
# ENRICH_MODE=off          # off | new | all
# ENRICH_CONCURRENCY=8
# ENRICH_DELAY_MS=30
# CALP_RELOAD_EACH_LV3=0   # 1 = reload page before each lv3 click
# CRAWL_SUBCATEGORIES=1
# MAX_SCROLL_ROUNDS=0
# HEADLESS=0
