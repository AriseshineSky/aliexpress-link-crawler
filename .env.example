# AliExpress crawler runtime config
ELASTICSEARCH_URL=http://user:password@host:9200
ELASTICSEARCH_INDEX_URLS=user1_aliexpress_us_product_urls
ELASTICSEARCH_BULK_CHUNK_SIZE=50

# Category seeds from: cd ../aliexpress-ds && uv run aliexpress-ds sync-categories
ELASTICSEARCH_INDEX_CATEGORIES=user1_aliexpress_crawl_categories
# CATEGORIES_ENABLED_ONLY=1
# Fallback YAML when ES categories unavailable (priority list — no women's/men's clothing)
# CATEGORIES_FILE=config/categories.priority.yaml
# Clothing + adult/sensitive blacklist (defaults in config/category_blacklist.yaml)
# CATEGORY_BLACKLIST_FILE=config/category_blacklist.yaml
# CATEGORY_BLACKLIST_TABS=women's_clothing,men's_clothing,novelty_&_special_use
# CATEGORY_BLACKLIST_KEYWORDS=clothing,apparel,sex toy,erotic,adult novelty

# Multi-device category claim (default on when ELASTICSEARCH_INDEX_CATEGORIES is set)
# CATEGORY_CLAIM_MODE=1
# DEVICE_ID=pc-a
# CLAIM_BATCH_SIZE=0          # 0 = CRAWL_WORKERS
# CLAIM_LEASE_SECONDS=7200
# CLAIM_HEARTBEAT_SECONDS=900
# CRAWL_RECLAIM_DONE=1        # 1 = re-crawl done URLs (cycle); 0 = skip after done
# Claim pick is random among eligible seeds (not priority order).

# Continuous loop: after a full pass, reset pending and repeat
# CRAWL_LOOP=1
# CRAWL_LOOP_SLEEP_SEC=120
# Discover calp lv3 → upsert wholesale URLs into ES as separate claimable seeds
# SUBCATEGORY_AS_SEEDS=1

# Category URL discovery (run before product crawl):
#   ./scripts/discover_categories.sh
#   .venv/bin/python discover_categories.py --site us
#   .venv/bin/python alilj.py --discover-categories --l1-only
# DISCOVER_SITE=us            # us | com

# Speed / crawl knobs (prefer slower to avoid captcha)
# REQUEST_DELAY_MS=2500,4500
# GOTO_SETTLE_MS=2000
# SCROLL_API_TIMEOUT_MS=4500
# SCROLL_FALLBACK_MS=2000
# CRAWL_SUBCATEGORIES=1
# HEADLESS=0
# Parallel category workers (each uses browser/worker-N). Keep 1 when captcha-heavy.
# CRAWL_WORKERS=1
# ENRICH_CONCURRENCY=4
# ENRICH_DELAY_MS=80
# LOGIN_RECOVERY_RETRIES=8
# Optional screen size for tiling headed windows (else auto-detect)
# SCREEN_WIDTH=1920
# SCREEN_HEIGHT=1080

# Listing URL filters (defaults in alilj.py)
# LISTING_MAX_PRICE=99
# LISTING_MIN_PRICE=
# LISTING_STAR_FILTER=4StarRating
# Sort by orders/sold (wholesale+category; also attached to calp). Empty to disable.
# LISTING_SORT_TYPE=total_tranpro_desc
# Empty string disables that filter.

# Local quality gate after enrich (page has NO review-count SortType)
# QUALITY_FILTER=1
# QUALITY_MAX_PRICE=100
# QUALITY_MIN_RATING=4.4
# QUALITY_MIN_REVIEWS=300
# QUALITY_MIN_SOLD=500

# Listing load mode is auto-detected (pagination vs infinite scroll).
# MAX_PAGES_PER_CATEGORY=0       # pagination cap; 0 = unlimited
# MAX_SCROLL_ROUNDS=0            # scroll cap; 0 = until consecutive empty rounds
# CONSECUTIVE_DUPLICATE_PAGES_TO_STOP=3
# CONSECUTIVE_DUPLICATE_SCROLLS_TO_STOP=10
